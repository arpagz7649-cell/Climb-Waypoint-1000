<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Climb: The Path of JSON</title>
    <style>
        body { background: #020617; color: #8b5cf6; font-family: monospace; text-align: center; }
        .box { border: 2px solid #8b5cf6; padding: 20px; display: inline-block; margin-top: 50px; }
        input { display: block; margin: 10px auto; padding: 8px; }
        button { background: #8b5cf6; color: white; border: none; padding: 10px 20px; cursor: pointer; }
    </style>
</head>
<body>
    <h1>🏔️ CLIMB: THE PATH OF JSON</h1>
    <div class="box" id="lobby">
        <h3>MASUKKAN DATA AKUN SELAMANYA</h3>
        <input type="text" id="user" placeholder="Username Acak">
        <input type="password" id="pass" placeholder="Password">
        <button onclick="kirimKeGudang()">DAFTAR / LOGIN</button>
    </div>

    <script>
        async function kirimKeGudang() {
            const username = document.getElementById('user').value;
            const password = document.getElementById('pass').value;

            // JS mengirim data ke Mesin Go Master
            try {
                const res = await fetch('http://localhost:8080/login', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ username, password })
                });
                const data = await res.json();
                alert(data.message + " | Bapak Checkpoint siap menunggu!");
            } catch (e) {
                alert("Mesin Go belum dinyalakan atau tidak terjangkau!");
            }
        }
    </script>
</body>
</html>
